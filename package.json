{
  "name": "whitenoise",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --import ./dist/telemetry/instrumentation.js dist/index.js",
    "dev": "npm run build && node --import ./dist/telemetry/instrumentation.js dist/index.js",
    "test": "vitest run --project unit --project integration",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:coverage": "vitest run --coverage --project unit --project integration",
    "test:e2e": "cross-env RUN_E2E=1 vitest run --project e2e"
  },
  "dependencies": {
    "@0xshariq/github-mcp-server": "^2.5.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@playwright/mcp": "^0.0.64",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.24",
    "cross-env": "^10.1.0",
    "esbuild": "^0.20.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
