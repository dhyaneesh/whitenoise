{
  "name": "dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build --prefix .. && concurrently \"npm run dev:server\" \"vite\"",
    "dev:server": "tsx server/index.ts",
